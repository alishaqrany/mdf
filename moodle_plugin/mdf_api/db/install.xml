      <INDEXES>
        <INDEX NAME="courseid_idx" UNIQUE="false" FIELDS="courseid"/>
        <INDEX NAME="target_idx" UNIQUE="false" FIELDS="targettype,targetid"/>
        <INDEX NAME="course_target_unique" UNIQUE="true" FIELDS="courseid,targettype,targetid"/>
      </INDEXES>
    </TABLE>

    <!-- ─── AI: Provider Configuration ─── -->
    <TABLE NAME="local_mdf_ai_config" COMMENT="AI provider API keys and settings">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="provider" TYPE="char" LENGTH="50" NOTNULL="true" COMMENT="gemini|mistral|cohere|openrouter|groq"/>
        <FIELD NAME="apikey" TYPE="text" NOTNULL="true" COMMENT="Encrypted API key"/>
        <FIELD NAME="model" TYPE="char" LENGTH="100" NOTNULL="false" COMMENT="Model identifier"/>
        <FIELD NAME="systemprompt" TYPE="text" NOTNULL="false" COMMENT="System prompt for the provider"/>
        <FIELD NAME="maxtokens" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="1024"/>
        <FIELD NAME="temperature" TYPE="number" LENGTH="4" DECIMALS="2" NOTNULL="true" DEFAULT="0.70"/>
        <FIELD NAME="enabled" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="provider_unique" UNIQUE="true" FIELDS="provider"/>
      </INDEXES>
    </TABLE>

