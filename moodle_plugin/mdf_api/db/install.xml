    <!-- ─── Social: Note Bookmarks ─── -->
    <TABLE NAME="local_mdf_note_bookmarks" COMMENT="Note bookmark tracking">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="noteid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="noteid_fk" TYPE="foreign" FIELDS="noteid" REFTABLE="local_mdf_study_notes" REFFIELDS="id"/>
        <KEY NAME="userid_fk" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="note_user_unique" UNIQUE="true" FIELDS="noteid, userid"/>
      </INDEXES>
    </TABLE>

    <!-- ─── Social: Note Comments ─── -->
    <TABLE NAME="local_mdf_note_comments" COMMENT="Note comments">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="noteid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="content" TYPE="text" NOTNULL="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="noteid_fk" TYPE="foreign" FIELDS="noteid" REFTABLE="local_mdf_study_notes" REFFIELDS="id"/>
        <KEY NAME="userid_fk" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="noteid_idx" UNIQUE="false" FIELDS="noteid"/>
      </INDEXES>
    </TABLE>

    <!-- ─── Social: Collaborative Sessions ─── -->
    <TABLE NAME="local_mdf_collab_sessions" COMMENT="Collaborative study sessions">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="title" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="description" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="groupid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="starttime" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="endtime" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="scheduled"/>
        <FIELD NAME="maxparticipants" TYPE="int" LENGTH="5" NOTNULL="true" DEFAULT="20"/>
        <FIELD NAME="topic" TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="groupid_fk" TYPE="foreign" FIELDS="groupid" REFTABLE="local_mdf_study_groups" REFFIELDS="id"/>
        <KEY NAME="createdby_fk" TYPE="foreign" FIELDS="createdby" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="status_idx" UNIQUE="false" FIELDS="status"/>
        <INDEX NAME="starttime_idx" UNIQUE="false" FIELDS="starttime"/>
      </INDEXES>
    </TABLE>

    <!-- ─── Social: Session Participants ─── -->
    <TABLE NAME="local_mdf_session_participants" COMMENT="Session participation">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="sessionid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timejoined" TYPE="int" LENGTH="10" NOTNULL="true"/>
