# Fastlane configuration for MDF Academy (Android)
# Setup: gem install fastlane

default_platform(:android)

platform :android do
  desc "Run Flutter tests"
  lane :test do
    sh("cd ../.. && flutter test")
  end

  desc "Build debug APK"
  lane :build_debug do
    sh("cd ../.. && flutter build apk --debug")
  end

  desc "Build release APK"
  lane :build_release do
    sh("cd ../.. && flutter build apk --release --obfuscate --split-debug-info=build/debug-info")
  end

  desc "Build release AAB for Play Store"
  lane :build_aab do
    sh("cd ../.. && flutter build appbundle --release --obfuscate --split-debug-info=build/debug-info")
  end

  desc "Deploy to Google Play (internal track)"
  lane :deploy_internal do
    build_aab
    upload_to_play_store(
      track: "internal",
      aab: "../../build/app/outputs/bundle/release/app-release.aab",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  desc "Promote internal to beta"
  lane :promote_beta do
    upload_to_play_store(
      track: "internal",
      track_promote_to: "beta",
    )
  end

  desc "Promote beta to production"
  lane :promote_production do
    upload_to_play_store(
      track: "beta",
      track_promote_to: "production",
    )
  end
end
